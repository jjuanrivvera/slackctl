      "verbs": ["list", "info", "history", "replies", "members", "create", "rename", "archive", "unarchive", "invite", "join", "leave", "kick", "set-topic", "set-purpose", "mark", "open", "close", "unreads"],
      "methods": {
        "list": "conversations.list", "info": "conversations.info", "history": "conversations.history",
        "replies": "conversations.replies", "members": "conversations.members", "create": "conversations.create",
        "rename": "conversations.rename", "archive": "conversations.archive", "unarchive": "conversations.unarchive",
        "invite": "conversations.invite", "join": "conversations.join", "leave": "conversations.leave",
        "kick": "conversations.kick", "set-topic": "conversations.setTopic", "set-purpose": "conversations.setPurpose",
        "mark": "conversations.mark", "open": "conversations.open", "close": "conversations.close",
        "unreads": "composite(users.conversations + conversations.info)"
