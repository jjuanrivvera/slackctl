  "profile_flag": "workspace",
  "profile_noun": "workspace",
  "api_method_total": 308,
  "api_method_source": "https://docs.slack.dev/reference/methods.json (official docs index data, 2026-07-06) — 308 entries, cross-checked against sitemap.xml (308 /reference/methods/* URLs)",
  "resources": [
