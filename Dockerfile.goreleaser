# Minimal runtime image for the prebuilt (static, CGO_ENABLED=0) binary that GoReleaser drops
# into the build context. Distroless keeps the image tiny and the attack surface small.
FROM gcr.io/distroless/static-debian12:nonroot
COPY slackctl /usr/bin/slackctl
ENTRYPOINT ["/usr/bin/slackctl"]
CMD ["--help"]
